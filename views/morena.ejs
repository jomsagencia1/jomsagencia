<%- include ('partials/header.ejs') %>  

<div class="container p-5 text-center" id="portfolio">

  <div class="d-flex flex-wrap justify-content-center gap-4 p-2 mb-3">
    <button class="btn filter-btn active" data-filter="all">Todos</button>
    <button class="btn filter-btn" data-filter="web">Websites</button>
    <button class="btn filter-btn" data-filter="branding">Design E Branding</button>
