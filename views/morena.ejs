    </div>

    <!-- PROJETO 2 -->
    <div class="portefolio-item social mb-5">
        <h4 style="color:#ffffff">Morena</h4>
        <br>
       <img src="/imgs/posts_morena.jpg" alt="" style="width: 500px;">
      
    </div>

    <div class="portefolio-item branding mb-5">
