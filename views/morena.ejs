    <br><br>

    <div id="carouselMorena" class="carousel slide" data-bs-ride="carousel">
      <div class="carousel-inner">

        <div class="carousel-item active">
          <div class="img-hover">
            <img src="/imgs/home_MORENA.png" class="d-block w-100">
            <div class="overlay-text">Homepage</div>
          </div>
        </div>

        <div class="carousel-item">
          <div class="img-hover">
            <img src="/imgs/sobremim_MORENA.png" class="d-block w-100">
            <div class="overlay-text">Sobre Mim</div>
          </div>
        </div>

        <div class="carousel-item">
          <div class="img-hover">
            <img src="/imgs/servicos_MORENA.png" class="d-block w-100">
            <div class="overlay-text">Serviços</div>
          </div>
        </div>

        <div class="carousel-item">
          <div class="img-hover">
            <img src="/imgs/Galeria_MORENA.png" class="d-block w-100">
            <div class="overlay-text">Galeria</div>
          </div>
        </div>

        <div class="carousel-item">
          <div class="img-hover">
            <img src="/imgs/contactos_MORENA.png" class="d-block w-100">
            <div class="overlay-text">Contactos</div>
          </div>
        </div>

      </div>

      <button class="carousel-control-prev" type="button" data-bs-target="#carouselMorena" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </button>

      <button class="carousel-control-next" type="button" data-bs-target="#carouselMorena" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
      </button>
    </div>
  </div>

  <!-- REDES SOCIAIS -->
  <div class="portefolio-item social mb-5">
    <h4 style="color:#ffffff">Morena</h4>
    <br>

    <div class="img-hover">
      <img src="/imgs/posts_morena.jpg" style="width: 900px;">
      <div class="overlay-text">Gestão de Redes Sociais</div>
    </div>
  </div>

  <!-- BRANDING -->
  <div class="portefolio-item branding mb-5">
    <h4 style="color:#ffffff;">Design E Branding</h4>
    <br>

    <div class="row">

      <div class="col-sm-4">
        <div class="img-hover">
          <img src="/imgs/logotipom.jpg" class="logos_design" style="border-radius: 50%;">
          <div class="overlay-text">Logótipo</div>
        </div>
      </div>

      <div class="col-sm-4">
        <div class="img-hover">
          <img src="/imgs/cartao_visitamorena.png" style="width: 300px;">
          <div class="overlay-text">Cartão de Visita</div>
        </div>
      </div>

      <div class="col-sm-4">
        <div class="img-hover">
          <img src="/imgs/mockup_morena_oferta.png" style="width: 300px;">
          <div class="overlay-text">Ofertas Especiais</div>
        </div>
      </div>

    </div>
  </div>

  <!-- MEDIA -->
  <div class="portefolio-item media mb-5">
    <h4 style="color:#ffffff">Multimédia</h4>
    <br>

    <div class="img-hover">
      <video autoplay loop muted playsinline class="videos_media">
        <source src="/videos/video1.mp4" type="video/mp4">
      </video>
      <div class="overlay-text">Vídeo Promocional</div>
    </div>

    <div class="img-hover">
      <video autoplay loop muted playsinline class="videos_media">
        <source src="/videos/video2.mp4" type="video/mp4">
      </video>
      <div class="overlay-text">Conteúdo Social</div>
    </div>

    <div class="img-hover">
      <video autoplay loop muted playsinline class="videos_media">
        <source src="/videos/video3.mp4" type="video/mp4">
      </video>
      <div class="overlay-text">Reel Criativo</div>
    </div>

    <div class="img-hover">
      <video autoplay loop muted playsinline class="videos_media">
        <source src="/videos/video4.mp4" type="video/mp4">
      </video>
      <div class="overlay-text">Edição Vídeo</div>
    </div>

  </div>

</div> 


<script>
  const buttons = document.querySelectorAll(".filter-btn");
  const items = document.querySelectorAll(".portefolio-item");

  buttons.forEach(button => {
    button.addEventListener("click", () => {

      buttons.forEach(btn => btn.classList.remove("active"));
      button.classList.add("active");

      const filter = button.getAttribute("data-filter");

      items.forEach(item => {
        if (filter === "all" || item.classList.contains(filter)) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      });

    });
  });
</script> 

