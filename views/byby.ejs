  
<%- include ('partials/header.ejs') %>  
 <div class="container p-5 text-center" id="portfolio">
   <div class="d-flex flex-wrap justify-content-center gap-4 p-2 mb-3">

      <button class="btn filter-btn active" data-filter="all">Todos</button>
      <button class="btn filter-btn" data-filter="web">Websites</button>
      <button class="btn filter-btn" data-filter="branding">Design E Branding</button>
      <button class="btn filter-btn" data-filter="social">Redes Sociais</button>
      <button class="btn filter-btn" data-filter="media">Multimédia</button>
    </div>

    <div class="portefolio-item web mb-5">

      <h4 style="color:#ffffff;">Website</h4>
      <br>
      <div id="carouselBybyBraids" class="carousel slide" data-bs-ride="carousel">
        <div class="carousel-inner">

          <div class="carousel-item active">
            <img src="/imgs/sobremim_bybybraids.png" class="d-block w-100">
          </div>

          <div class="carousel-item">
            <img src="/imgs/servicos_bybybraids.png" class="d-block w-100">
          </div>

          <div class="carousel-item">
            <img src="/imgs/galeria_BybyBraids.png" class="d-block w-100">
          </div>

          <div class="carousel-item">
            <img src="/imgs/contactos_bybybraids.png" class="d-block w-100">
          </div>

        </div>

        <button class="carousel-control-prev" type="button" data-bs-target="#carouselBybyBraids" data-bs-slide="prev">
          <span class="carousel-control-prev-icon"></span>
        </button>

        <button class="carousel-control-next" type="button" data-bs-target="#carouselBybyBraids" data-bs-slide="next">
          <span class="carousel-control-next-icon"></span>
        </button>
      </div>

    </div>

    <!-- PROJETO 2 -->
    <div class="portefolio-item social mb-5">
        <h4 style="color:#ffffff">Redes Sociais</h4>
        <br>
      <img src="/imgs/sm_byby.png" alt="" style="border-color: 2px solid #000; border-radius: 10px; width: 300px;">
    </div>

    <div class="portefolio-item branding mb-5">

    <h4 style="color: #ffffff;">Design E Branding</h4>
    <p class="text-muted text-white" >Logotipo</p>
    <br>
          <img src="/imgs/logotipob.jpeg" class="logos_design" style="width: 200px; border-radius: 50%;">

    </div>

    <div class="portefolio-item media mb-5">
        
    </div>

    <button class="btn-voltar" onclick="document.getElementById('portfolio').scrollIntoView({behavior: 'smooth'});">Voltar</button>
</div> 
 <script>
  const buttons = document.querySelectorAll(".filter-btn");
  const items = document.querySelectorAll(".portefolio-item");

  buttons.forEach(button => {
    button.addEventListener("click", () => {

      // botão ativo
      buttons.forEach(btn => btn.classList.remove("active"));
      button.classList.add("active");

      const filter = button.getAttribute("data-filter");

      items.forEach(item => {
        if (filter === "all" || item.classList.contains(filter)) {
          item.style.display = "block";
        } else {
          item.style.display = "none";
        }
      });

    });
  });
</script> 
    
